{
	"$id": "mvp",
	"$schema": "https://spec.mainvec.com/mvpspec/0.2/schema/2026-01-15",
	"name": "mvp",
	"title": "Mainvec Platform Toolkit",
	"desc": "Command-line toolkit for Mainvec Platform",
	"version": "v0.1",
	"namespace": "mvpNS",
	"gen_options": {
		"go_package": "github.com/mainvec/mvep/toolkit/mvpapi;mvp",
		"go_api_package": "github.com/mainvec/mvep/toolkit/mvpapi/api;api"
	},
	"commands": {
		"InitializeCmd": {
			"title": "Initialize a new MVP spec",
			"alias": "init",
			"fields": {
				"name": {
					"fnum": 1,
					"type": "string",
					"tags": [
						"required"
					]
				},
				"namespace": {
					"fnum": 2,
					"type": "string",
					"alias": "ns"
				}
			}
		},
		"GenerateCmd": {
			"title": "Generate code from MVP schema",
			"alias": "generate",
			"fields": {
				"in": {
					"fnum": 1,
					"alias": "in",
					"title": "input mvp spec file",
					"type": "string",
					"tags": [
						"required"
					]
				},
				"outdir": {
					"fnum": 2,
					"type": "string"
				},
				"lang": {
					"fnum": 3,
					"type": "string",
					"tags": [
						"required"
					]
				},
				"format": {
					"fnum": 4,
					"type": "string",
					"title": "serialization format (plain=plain json, pb3=protobuf)"
				}
			}
		},
		"ValidateCmd": {
			"title": "Validate MVP spec",
			"alias": "validate",
			"fields": {
				"in": {
					"fnum": 1,
					"alias": "in",
					"title": "input mvp spec file",
					"type": "string",
					"tags": [
						"required"
					]
				}
			},
			"resultFields": {
				"valid": {
					"fnum": 1,
					"type": "boolean"
				},
				"errors": {
					"fnum": 5,
					"type": "string",
					"repeated": true
				},
				"warnings": {
					"fnum": 10,
					"type": "string",
					"repeated": true
				}
			}
		}
	}
}
