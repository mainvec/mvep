{
	"$schema": "../resources/schemas/wop_service.schema_latest_draft.json",
	"$id": "https://workoak.com#",
	"name": "wodb2",
	"namespace": "wo",
	"title": "WO DB",
	"base": "github.com/workoak/wo/wop/wopdb",
	"description": "Core WO DB service providing DB as a service",
	"gen_options": {
		"go_package": "github.com/workoak/wo/wop/wopdb/wopdb2api"
	},
	"recordsDefs": {
		"WODbParams": {
			"name": "WODbParams",
			"fields": {
				"dbname": {
					"fnum": 1,
					"type": "string"
				},
				"authtoken": {
					"fnum": 2,
					"type": "string"
				},
				"params": {
					"fnum": 10,
					"type": "map",
					"valueType": "string"
				}
			}
		},
		"FieldDesc": {
			"name": "FieldDesc",
			"fields": {
				"name": {
					"fnum": 1,
					"type": "string"
				},
				"typeOid": {
					"fnum": 2,
					"type": "uint32"
				},
				"typeSize": {
					"fnum": 3,
					"type": "sint32"
				},
				"typeModifier": {
					"fnum": 4,
					"type": "sint32"
				},
				"format": {
					"fnum": 5,
					"type": "int32"
				},
				"tableOid": {
					"fnum": 6,
					"type": "uint32"
				},
				"posInTable": {
					"fnum": 7,
					"type": "uint32"
				}
			}
		},
		"RowDesc": {
			"name": "RowDesc",
			"fields": {
				"fields": {
					"fnum": 1,
					"type": "record",
					"recordDefName": "FieldDesc",
					"repeated": true
				}
			}
		},
		"DataValue": {
			"name": "DataValue",
			"fields": {
				"value": {
					"fnum": -1,
					"type": "oneOf",
					"fields": {
						"stringV": {
							"type": "string",
							"fnum": 1
						},
						"boolV": {
							"type": "boolean",
							"fnum": 2
						},
						"intV": {
							"type": "int32",
							"fnum": 3
						},
						"longV": {
							"type": "int64",
							"fnum": 4
						},
						"floatV": {
							"type": "float",
							"fnum": 5
						},
						"doubleV": {
							"type": "double",
							"fnum": 6
						},
						"bytesV": {
							"type": "bytes",
							"fnum": 7
						},
						"timeStampV": {
							"type": "timestamp",
							"fnum": 8
						},
						"durationV": {
							"type": "duration",
							"fnum": 9
						}
					}
				}
			}
		},
		"DataRow": {
			"name": "DataRow",
			"fields": {
				"values": {
					"fnum": 1,
					"type": "record",
					"recordDefName": "DataValue",
					"repeated": true
				}
			}
		},
		"DataRows": {
			"name": "DataRows",
			"fields": {
				"rowDesc": {
					"fnum": 1,
					"type": "record",
					"recordDefName": "RowDesc"
				},
				"rows": {
					"fnum": 2,
					"type": "record",
					"recordDefName": "DataRow",
					"repeated": true
				}
			}
		}
	},
	"commands": {
		"WODbDqlCmd": {
			"title": "WODB DQL Cmd. Only query commands, e.g. SELECT statements",
			"state_type": "cluster",
			"fields": {
				"dql": {
					"fnum": 1,
					"type": "string",
					"repeated": false
				},
				"DBParam": {
					"fnum": 2,
					"type": "recRef",
					"$ref": "#/recordsDefs/WODbParams"
				}
			},
			"resultFields": {
				"rows": {
					"fnum": 1,
					"type": "recRef",
					"$ref": "#/recordsDefs/DataRows"
				}
			}
		},
		"WODbDmlCmd": {
			"title": "WODB DML Cmd. Data Manipulation Stmts, e.g. INSERT, UPDATE, DELETE statements",
			"state_type": "cluster",
			"fields": {
				"dml": {
					"fnum": 1,
					"type": "string",
					"repeated": false
				},
				"DBParam": {
					"fnum": 2,
					"type": "record",
					"recordDefName": "WODbParams"
				}
			}
		}
	}
}