{
	"$id": "pizzaHubId",
	"$schema": "resources/wopapi/wopspec/0.1/schema/2023-09-19",
	"name": "pizzahub",
	"namespace": "foodie",
	"base": "github.com/workoak/pizzahub",
	"commands": {
		"OrderPizzaCmd": {
			"title": "Order a pizza",
			"fields": {
				"size":{
					"fnum": 1,
					"type": "string"
				},
				"type":{
					"fnum": 2,
					"type": "string"
				},
				"toppings":{
					"fnum": 3,
					"type": "string",
					"repeated": true
				},
				"address":{
					"fnum": 4,
					"type": "recRef",
					"$ref": "#/recordsDefs/Address"
				}
			},
			"resultFields": {
				"order_status":{
					"fnum": 1,
					"type": "string"
				}
			}

		}
	},
	"recordsDefs": {
		"Address":{
			"name": "Address",
			"fields": {
				"street":{
					"fnum": 1,
					"type": "string"
				},
				"city":{
					"fnum": 2,
					"type": "string"
				},
				"country":{
					"fnum": 3,
					"type": "string"
				}
			}
		}
	}

	

}